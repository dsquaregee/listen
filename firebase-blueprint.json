{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Music categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "visualIdentity": { "type": "string" },
        "order": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug"]
    },
    "Album": {
      "title": "Album",
      "description": "Music albums",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "duration": { "type": "integer" },
        "coverUrl": { "type": "string" },
        "hlsUrl": { "type": "string" },
        "videoHlsUrl": { "type": "string" },
        "categoryId": { "type": "string" },
        "description": { "type": "string" },
        "featured": { "type": "boolean" },
        "tier": { "type": "string" },
        "playCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "artist", "categoryId"]
    },
    "Session": {
      "title": "Listening Session",
      "description": "Analytics tracking for user listening behavior",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "albumId": { "type": "string" },
        "albumTitle": { "type": "string" },
        "duration": { "type": "integer" },
        "startTime": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "city": { "type": "string" }
          }
        }
      },
      "required": ["userId", "albumId", "startTime"]
    }
  },
  "firestore": {
    "categories": {
      "schema": "Category",
      "description": "Collection of music categories"
    },
    "albums": {
      "schema": "Album",
      "description": "Collection of music albums"
    },
    "listening_sessions": {
      "schema": "Session",
      "description": "Historical record of all playback sessions"
    }
  }
}
