{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "tier": { "type": "string", "enum": ["free", "premium"] },
        "stripeCustomerId": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "subscriptionStatus": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "GuestMetric": {
      "title": "Guest Metric",
      "description": "Telemetry and analytics for guests",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "guestId": { "type": "string" },
        "path": { "type": "string" },
        "timestamp": { "type": "number" },
        "processedAt": { "type": "string", "format": "date-time" },
        "expireAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile and subscription status"
    },
    "guest_metrics/{metricId}": {
      "schema": "GuestMetric",
      "description": "Telemetry and guest analytics"
    }
  }
}
