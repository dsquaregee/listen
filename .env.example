# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Cloud Storage (Required for audio processing)
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=

# Stripe (Required for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID="price_1TWglGPJj41anICeeNRRqmLc"
# Success/Cancel URLs are computed automatically relative to the site origin
# but can be overridden here if needed by the server
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Media CDN Support
VITE_CDN_URL=
