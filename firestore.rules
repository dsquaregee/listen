rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // GLOBAL HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'dsquaregee@gmail.com'
      ); 
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // ---------------------------------------------------------
    // CATCH-ALL DENY
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // USERS COLLECTION
    // ---------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      (
                        // Standard user creation
                        (incoming().tier == 'free' && (!('isAdmin' in incoming()) || incoming().isAdmin == false)) ||
                        // Admin self-bootstrap creation
                        (request.auth.token.email == 'dsquaregee@gmail.com' && incoming().tier == 'premium' && incoming().isAdmin == true)
                      );
      allow update: if (isOwner(userId) || isAdmin()) && 
                      (
                        // User updating their own profile
                        (isOwner(userId) && 
                          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'tier', 'stripeCustomerId', 'subscriptionId', 'subscriptionStatus']) &&
                          (!('isAdmin' in incoming()) || incoming().isAdmin == existing().isAdmin)
                        ) ||
                        // Admin updating anything
                        isAdmin()
                      );
    }

    // ---------------------------------------------------------
    // CATEGORIES (Read only for users, Write for Admin)
    // ---------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------
    // ALBUMS (Read only for users, Write for Admin)
    // ---------------------------------------------------------
    match /albums/{albumId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Allow playCount increments for signed in users
      allow update: if isVerified() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['playCount']) &&
                      incoming().playCount == existing().playCount + 1;
    }

    // ---------------------------------------------------------
    // PLAYLISTS (User specific)
    // ---------------------------------------------------------
    match /playlists/{playlistId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isOwner(incoming().userId) && isValidId(playlistId);
      allow update: if isOwner(existing().userId) && incoming().userId == existing().userId;
      allow delete: if isOwner(existing().userId);
    }
    
    // ---------------------------------------------------------
    // ADMINS LIST (Self-Bootstrap check)
    // ---------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow create: if isVerified() && isOwner(adminId) && (request.auth.token.email == 'dsquaregee@gmail.com' || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // LISTENING SESSIONS (Analytics)
    // ---------------------------------------------------------
    match /listening_sessions/{sessionId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isOwner(incoming().userId);
    }
  }
}
