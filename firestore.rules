rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny - Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Pillar 8 constraint: No exists() inside allow list
    function isAdminToken() {
      return isSignedIn() && request.auth.token.get('email', '').lower() == 'dsquaregee@gmail.com';
    }

    // DB-backed admin check for single-doc operations
    function isAdminDB() {
      return isAdminToken() || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    // --- End Helpers ---

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        let requiredKeys = ['uid', 'email', 'displayName'];
        // Pillar 2: Strict Keys & Identity Integrity
        return data.keys().hasAll(requiredKeys) &&
               data.uid == userId &&
               data.email is string && data.email.size() <= 200 &&
               data.displayName is string && data.displayName.size() <= 200;
      }

      // Pillar 6: PII Isolation
      allow get: if isOwner(userId) || isAdminDB();
      // Pillar 8: Secure List Queries (Avoid exists in list)
      allow list: if isAdminToken(); 

      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if (isOwner(userId) || isAdminDB()) && (
        // Tiered identity logic: allow specific state updates or full admin control
        incoming().diff(existing()).affectedKeys().hasAny(['tier', 'isPremium', 'displayName', 'photoURL', 'totalMinutesStreamed', 'updatedAt', 'stripeCustomerId']) ||
        isAdminDB()
      );
    }

    // 2. Categories
    match /categories/{categoryId} {
      allow read: if true; 
      allow write: if isAdminDB();
    }

    // 3. Albums
    match /albums/{albumId} {
      allow read: if true; 
      allow update: if (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['playCount', 'updatedAt'])) || isAdminDB();
      allow create, delete: if isAdminDB();
    }

    // 4. Playlists
    match /playlists/{playlistId} {
      function isValidPlaylist(data) {
        return data.userId == request.auth.uid &&
               data.name is string && data.name.size() <= 100 &&
               data.albumIds is list && data.albumIds.size() <= 1000;
      }

      // Pillar 8: Secure List Queries - restrict to owner
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminDB());
      
      allow create: if isSignedIn() && isValidPlaylist(incoming()) && isValidId(playlistId);
      
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasAny(['name', 'albumIds', 'updatedAt']) ||
        isAdminDB()
      );
      
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminDB());
    }
    
    // 5. Favorites
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || (existing() != null && existing().userId == request.auth.uid));
    }

    // 6. Admins
    match /admins/{adminId} {
      allow read: if isAdminDB();
      allow write: if false; 
    }
  }
}
