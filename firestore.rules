rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Catch-All Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isBusinessUser() {
      let role = getUserRole();
      return role == 'business_basic' || role == 'business_pro';
    }

    function getBusinessId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 100
        && data.tier in ['free', 'premium', 'business_basic', 'business_pro']
        && data.role in ['consumer', 'business_basic', 'business_pro', 'admin'];
    }

    function isValidBusiness(data) {
      return data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 200
        && data.ownerId == request.auth.uid
        && data.plan in ['business_basic', 'business_pro']
        && data.active is bool;
    }

    // --- Collection Matches ---

    // Users: Only owner can read/write. Roles/Tier/BusinessId are PROTECTED from client write.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'consumer' && incoming().tier == 'free';
      allow update: if (isOwner(userId) || isAdmin()) && (
        isAdmin() || (
           incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
           && incoming().updatedAt == request.time
        )
      );
    }

    // Admins: Read-only for admins
    match /admins/{userId} {
      allow read: if isAdmin();
    }

    // Businesses
    match /businesses/{businessId} {
      allow read: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && isValidBusiness(incoming()) && isValidId(businessId));
      allow update: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid && isValidBusiness(incoming()));
    }

    // Schedules
    match /business_schedules/{businessId} {
      allow read: if isAdmin() || (isSignedIn() && getBusinessId() == businessId);
      allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
    }

    // Devices
    match /business_devices/{deviceId} {
      allow read: if isAdmin() || (isSignedIn() && incoming().businessId == getBusinessId());
      allow write: if isAdmin() || (isSignedIn() && incoming().businessId == getBusinessId());
    }

    // Analytics
    match /business_analytics/{businessId} {
      allow read: if isAdmin() || (isSignedIn() && getBusinessId() == businessId);
    }

    // Ambience Scenes
    match /ambience_scenes/{sceneId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() || (isSignedIn() && isBusinessUser());
    }

    // Metrics (Trackers)
    match /guest_metrics/{metricId} {
      allow create: if true;
      allow read: if true;
    }

    // Legacy Content (Albums, Categories) - Read only for everyone
    match /albums/{id} { allow read: if true; }
    match /categories/{id} { allow read: if true; }
    match /playlists/{id} {
      allow read, write: if isSignedIn() && (existing().userId == request.auth.uid || incoming().userId == request.auth.uid);
    }
  }
}
