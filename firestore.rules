rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Comprehensive Admin Check
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'dsquaregee@gmail.com' ||
        request.auth.uid == 'T9yg2h3VU7c5HSL0Td69Z9FfVQz1'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    // --- End Helpers ---

    // 1. Users
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // 2. Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Albums
    match /albums/{albumId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn();
    }

    // 4. Playlists
    match /playlists/{playlistId} {
      // Allow listing for signed in users - search results will be naturally restricted if they query their own
      allow list: if isSignedIn();
      allow get, write: if isSignedIn() && (
        isAdmin() || 
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // 5. Favorites
    match /favorites/{favoriteId} {
      allow list: if isSignedIn();
      allow get, write: if isSignedIn() && (
        isAdmin() || 
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // GLOBAL CATCH-ALL
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
