rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isMaster() {
      return request.auth != null && (
        request.auth.uid == 'T9yg2h3VU7c5HSL0Td69Z9FfVQz1' ||
        request.auth.token.get('email', '').lower() == 'dsquaregee@gmail.com'
      );
    }

    // BROAD READ FOR ALL COLLECTIONS
    // This will temporarily resolve all "Missing permissions" on LIST/GET operations
    match /{document=**} {
      allow read: if true;
      allow write: if isMaster();
    }

    // Special case for user's own data and playCounts
    match /albums/{albumId} {
      allow update: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if isMaster() || (request.auth != null && request.auth.uid == userId);
    }
  }
}
