rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // robust admin check using both UID and email (defensive)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'T9yg2h3VU7c5HSL0Td69Z9FfVQz1' ||
        request.auth.token.get('email', '') == 'dsquaregee@gmail.com' ||
        request.auth.token.email == 'dsquaregee@gmail.com'
      );
    }
    // --- End Helpers ---

    // USERS - Full access for owner or admin
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // CATEGORIES - Publicly readable
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ALBUMS - Publicly readable
    match /albums/{albumId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isSignedIn(); // Allow updating playCount
    }

    // PLAYLISTS - Owner or admin
    match /playlists/{playlistId} {
      // allow list for the owner/admin
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow get, write: if isSignedIn() && (
        isAdmin() || 
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // FAVORITES - Owner or admin
    match /favorites/{favoriteId} {
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow get, write: if isSignedIn() && (
        isAdmin() || 
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // GLOBAL CATCH-ALL FOR ADMIN
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
