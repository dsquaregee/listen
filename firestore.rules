rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - Deny all by default, except for admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Safe admin check using token email (Primary Admin dsquaregee@gmail.com)
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email', '').lower() == 'dsquaregee@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    // --- End Helpers ---

    // 1. Users Collection
    match /users/{userId} {
      allow get, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow list: if isAdmin();
    }

    // 2. Categories (Public)
    match /categories/{categoryId} {
      allow read: if true;
    }

    // 3. Albums (Public)
    match /albums/{albumId} {
      allow read: if true;
      // Allow incrementing playCount for signed in users
      allow update: if (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['playCount', 'updatedAt'])) || isAdmin();
    }

    // 4. Playlists
    match /playlists/{playlistId} {
      // Explicitly allow list queries for the owner
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Allow get and write
      allow get, write: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource == null && incoming().userId == request.auth.uid) ||
        isAdmin()
      );
    }

    // 5. Favorites (Optional separate collection, usually handled via 'Liked' playlist)
    match /favorites/{favoriteId} {
      allow read, write: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource == null && incoming().userId == request.auth.uid)
      );
    }

    // 6. Admins Collection (Specific doc access)
    match /admins/{adminId} {
      allow get: if isSignedIn() && (adminId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
    }
  }
}
