rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow everyone to record and read metrics (Server uses this as fallback)
    match /guest_metrics/{metricId} {
      allow create, read: if true;
      allow update, delete: if false; 
    }

    // Default allow for other collections to facilitate development
    // In a production app, we would restrict this to authenticated users.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
