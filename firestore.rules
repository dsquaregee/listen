rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Master Admin Helper (using UID for rock-solid identity)
    function isMasterAdmin() {
      return request.auth != null && (
        request.auth.uid == 'T9yg2h3VU7c5HSL0Td69Z9FfVQz1' ||
        request.auth.token.email == 'dsquaregee@gmail.com'
      );
    }
    
    // Allow users to update their own profile and read public ones
    match /users/{userId} {
      allow read: if true;
      allow write: if isMasterAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // Public content
    match /categories/{id} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }
    
    match /albums/{id} {
      allow read: if true;
      allow write: if isMasterAdmin();
      // Allow users to update play logs or specific tracks
      allow update: if request.auth != null;
    }

    // System health
    match /system/{id} {
      allow read, write: if isMasterAdmin();
    }

    // Playlists & Favorites
    match /playlists/{id} {
      allow read: if true; 
      allow write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
    
    match /favorites/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Global Catch-all (Deny by default)
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }
  }
}
